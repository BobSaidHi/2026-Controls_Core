                </mxCell>
                <mxCell id="48" value="&lt;div&gt;&lt;span&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;Safety Task&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;align=left;fontSize=14;" parent="31" vertex="1">
                    <mxGeometry x="960" y="30" width="100" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b&gt;Implementation Notes&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;font style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;- Although all&amp;nbsp;&lt;span style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); background-color: transparent;&quot;&gt;&lt;font style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;outputs&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;div style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;font style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); background-color: transparent;&quot;&gt;have been&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); background-color: transparent;&quot;&gt;depicted as per state (More), they will moved to state transitions (Mealy) in the implementation&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;font style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); background-color: transparent;&quot;&gt;-&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;This may be split into to parallel software FSMs, one per controller, which may improve reliability.&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/div&gt;- Last year, we ran the&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;FSM at 9 Hz&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;- This loop may be overridden manually for testing&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;- Backfeed controls have been moved to hardware as of last year&lt;/font&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;align=left;fontSize=14;" parent="31" vertex="1">
                    <mxGeometry x="10" y="40" width="290" height="410" as="geometry"/>
                </mxCell>
                <mxCell id="43" value="&lt;div&gt;&lt;font&gt;&lt;span&gt;&lt;b&gt;Notes for Testing:&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;font&gt;&lt;span&gt;- May need to&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;limit how&lt;/span&gt;&lt;/font&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font&gt;fast the variable load&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font&gt;can change to promote stabiltiy&lt;/font&gt;&lt;/span&gt;&lt;div&gt;&lt;font&gt;&lt;span&gt;-&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;text-align: center; background-color: transparent;&quot;&gt;May need to watch for undervoltage condition, but this may be unneeded and add complexity&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;align=left;fontSize=20;" parent="31" vertex="1">
                    <mxGeometry x="10" y="470" width="290" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="59" value="&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;font-size: 20px; background-color: transparent;&quot;&gt;&lt;b style=&quot;&quot;&gt;Load Inputs&lt;/b&gt;&lt;/span&gt;&lt;b style=&quot;background-color: transparent; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); font-size: 20px;&quot;&gt;&amp;nbsp;&amp;amp; Variables&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 20px; background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;safetyTask = (ESTOP || loadDisconnect)&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;loadDisconnect = PCCCurrent &amp;lt; (0 + iHysteresis)&lt;/span&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;font style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;producingPositivePower&amp;nbsp;&lt;/span&gt;&lt;font&gt;=&amp;nbsp;&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/span&gt;&lt;font&gt;&lt;span style=&quot;font-size: 20px; background-color: transparent;&quot;&gt;PCCVoltage &amp;gt;&lt;/span&gt;&lt;font style=&quot;font-size: 20px; background-color: transparent; scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;font-size: 20px; text-wrap-mode: nowrap; background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18)); text-align: center;&quot;&gt;&amp;nbsp; &amp;nbsp; (backFeedVoltage +&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 20px; text-wrap-mode: nowrap; background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18)); text-align: center;&quot;&gt;vHysteresisWindow/2)&lt;/span&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 20px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;div style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(75, 75, 75) rgb(27, 29, 30); background-color: rgb(255, 255, 255); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp; &amp;nbsp; Note: Previous versions&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;included a&lt;/span&gt;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18)); text-align: center; text-wrap-mode: nowrap;&quot;&gt;&amp;nbsp;fixed stage references of &amp;gt; 6 V (?).&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;align=left;fontSize=14;" vertex="1" parent="31">
                    <mxGeometry x="570" y="750" width="660" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="60" value="&lt;div&gt;&lt;span style=&quot;font-size: 20px; background-color: transparent;&quot;&gt;&lt;b style=&quot;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Nacelle Inputs &amp;amp; Variables&lt;/font&gt;&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 20px; text-wrap-mode: nowrap; scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); text-align: center; background-color: rgb(255, 255, 255); color: rgb(63, 63, 63);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(63, 63, 63);&quot;&gt;&lt;font style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(63, 63, 63);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(63, 63, 63);&quot;&gt;steadyRPM&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(192, 192, 192);&quot;&gt;&amp;nbsp;=&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;font style=&quot;font-size: 20px; text-wrap-mode: nowrap; scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); text-align: center; background-color: rgb(255, 255, 255); color: rgb(63, 63, 63);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(63, 63, 63);&quot;&gt;(dRPM/dt &amp;lt; 20 RPM/s)&lt;/span&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px; text-wrap-mode: nowrap; scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); text-align: center; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(63, 63, 63);&quot;&gt;targetRPMExceeded = (RPM &amp;gt; targetRPM)&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px; text-wrap-mode: nowrap; scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); text-align: center; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(63, 63, 63);&quot;&gt;targetRPMMet = RPM &amp;lt; (targetRPM - sHysteresisWindow)&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px; text-wrap-mode: nowrap; scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); text-align: center; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(63, 63, 63);&quot;&gt;Note: Hysteresis may not be ideal and should not be&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px; text-wrap-mode: nowrap; scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); text-align: center; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251); color: rgb(63, 63, 63);&quot;&gt;&amp;nbsp; &amp;nbsp; needed if PID is well tuned&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;align=left;fontSize=14;" vertex="1" parent="31">
