{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build API Docs (Windows)",
            "type": "shell",
            "command": ".\\docs\\Docs_RunDoxygen.bat",
        },
        {
            "label": "Build & Open API Docs (Windows)",
            "type": "shell",
            "command": ".\\docs\\Docs_RunDoxygenOpen.bat",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Compile Common Tests (WT32-ETH01) (A-CLI)",
            "type": "shell",
            "command": "C:/Program Files/Arduino CLI/arduino-cli",
            "args": [
                "compile",
                "--fqbn",
                "esp32:esp32:wt32-eth01",
                "${workspaceFolder}/Common/Common.ino",
                "--log"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Upload Common Tests (WT32-ETH01) (A-CLI)",
            "type": "shell",
            "command": "C:/Program Files/Arduino CLI/arduino-cli",
            "args": [
                "upload",
                "-p",
                "COM18",
                "--fqbn",
                "esp32:esp32:wt32-eth01",
                "${workspaceFolder}/Common/Common.ino",
                "--log"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Compile & Upload Common Tests (WT32-ETH01) (A-CLI)",
            "dependsOn": [
                "Compile Common Tests (WT32-ETH01) (A-CLI)",
                "Upload Common Tests (WT32-ETH01) (A-CLI)"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Compile Common Tests (ESP32C6) (A-CLI)",
            "type": "shell",
            "command": "C:/Program Files/Arduino CLI/arduino-cli",
            "args": [
                "compile",
                "--fqbn",
                "esp32:esp32:esp32c6",
                "${workspaceFolder}/Common/Common.ino",
                "--log"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Upload Common Tests (ESP32C6) (A-CLI)",
            "type": "shell",
            "command": "C:/Program Files/Arduino CLI/arduino-cli",
            "args": [
                "upload",
                "-p",
                "COM18",
                "--fqbn",
                "esp32:esp32:esp32c6",
                "${workspaceFolder}/Common/Common.ino",
                "--log"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Compile & Upload Common Tests (ESP32C6) (A-CLI)",
            "dependsOn": [
                "Compile Common Tests (ESP32C6) (A-CLI)",
                "Upload Common Tests (ESP32C6) (A-CLI)"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Setup Arduino CLI",
            "type": "shell",
            "command": "cd \"C:/Program Files/Arduino CLI/\" && arduino-cli core update-index && arduino-cli core install esp32:esp32",
            "problemMatcher": [],
            "group": {
                "kind": "none",
                "isDefault": false
            }
        },
        {
            "label": "List Devices (A-CLI)",
            "type": "shell",
            "command": "cd \"C:/Program Files/Arduino CLI/\" && arduino-cli board list",
            "problemMatcher": [],
            "group": {
                "kind": "none",
                "isDefault": false
            }
        },
        {
            "label": "Setup SysLinks (Windows)",
            "type": "shell",
            "command": ".\\scripts\\setupSymlinks.bat",
            "problemMatcher": [],
            "group": {
                "kind": "none",
                "isDefault": false
            }
        } /*,
        {
            "label": "Build WireViz Demo01 (Windows)",
            "type": "shell",
            "command": ".\\docs\\wireviz\\demo01\\build-wireviz_demo01.bat",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Build WireViz Diagram (Windows)",
            "type": "shell",
            "command": "docs\\wireviz\\build-wireviz_mainDiagram.bat",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }*/
    ]
}